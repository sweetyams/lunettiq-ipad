{
  "name": "lunettiq-ipad",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "echo '⚠ Use pnpm ios (not dev). Expo Go cannot run native modules.' && exit 1",
    "ios": "expo run:ios",
    "start": "expo start --dev-client",
    "setup": "bash scripts/setup.sh",
    "prepare": "git config core.hooksPath .githooks",
    "sim:ipad": "expo run:ios --device 'iPad Pro 13 Lunettiq'",
    "build:dev": "eas build --platform ios --profile development",
    "build:preview": "eas build --platform ios --profile preview",
    "build:prod": "eas build --platform ios --profile production",
    "verify": "tsx scripts/verify.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:a11y": "tsx scripts/audit-accessibility.ts",
    "audit:perf": "tsx scripts/audit-performance.ts",
    "audit:design": "tsx scripts/audit-design-drift.ts",
    "audit:privacy": "tsx scripts/audit-privacy-mode.ts",
    "audit:offline": "tsx scripts/audit-offline-awareness.ts",
    "prebuild": "expo prebuild --clean",
    "prebuild:clean": "rm -rf ios && expo prebuild --clean",
    "pod-install": "cd ios && pod install",
    "doctor": "npx expo-doctor",
    "check-deps": "expo install --check",
    "nuke": "rm -rf node_modules .expo ios android && pnpm install && expo prebuild --clean",
    "logs": "xcrun simctl spawn 'iPad Pro 13 Lunettiq' log stream --level=error --style=compact",
    "logs:all": "xcrun simctl spawn 'iPad Pro 13 Lunettiq' log stream --level=debug --style=compact --predicate 'process == \"Lunettiq\"'",
    "android": "expo run:android"
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "@clerk/clerk-expo": "^2.5.0",
    "@expo/metro-runtime": "~57.0.3",
    "@nozbe/simdjson": "3.1.0-wmelon1",
    "@nozbe/watermelondb": "^0.27.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@tanstack/react-query": "^5.50.0",
    "expo": "~57.0.4",
    "expo-application": "^57.0.0",
    "expo-auth-session": "~57.0.2",
    "expo-camera": "~57.0.1",
    "expo-constants": "~57.0.3",
    "expo-file-system": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-manipulator": "~57.0.2",
    "expo-image-picker": "^57.0.2",
    "expo-linking": "~57.0.2",
    "expo-local-authentication": "^57.0.0",
    "expo-notifications": "~57.0.6",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-web-browser": "~57.0.0",
    "lucide-react-native": "^1.23.0",
    "nanoid": "^5.1.16",
    "nativewind": "^4.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css-interop": "^0.2.6",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-mmkv": "^3.0.0",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@foundry/method": "github:Pencilz-Foundry/foundry-method",
    "@testing-library/react-native": "^14.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "~19.2.17",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^3.4.0",
    "typescript": "~6.0.3",
    "vitest": "^2.0.0"
  }
}
