{
  "name": "lunettiq-ipad",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "ios": "expo run:ios",
    "build:dev": "eas build --platform ios --profile development",
    "build:preview": "eas build --platform ios --profile preview",
    "build:prod": "eas build --platform ios --profile production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "prebuild": "expo prebuild --clean",
    "android": "expo run:android"
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "@clerk/clerk-expo": "^2.5.0",
    "@nozbe/watermelondb": "^0.27.0",
    "@tanstack/react-query": "^5.50.0",
    "expo": "~52.0.0",
    "expo-camera": "~16.0.0",
    "expo-image": "~2.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "lucide-react-native": "^0.400.0",
    "nativewind": "^4.0.0",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-mmkv": "^3.0.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.14.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.5.0",
    "@types/node": "^26.1.0",
    "@types/react": "~18.3.0",
    "eslint": "^9.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.5.0",
    "vitest": "^2.0.0"
  }
}
